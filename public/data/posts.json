[
  {
    "id": "22cdeea0-2b57-41a4-8d66-ee52c4e2afd8",
    "date": "2026-06-23",
    "category": "励志",
    "title": "凌晨五点",
    "content": "凌晨五点的街道很安静，路灯还没灭，早餐摊刚出第一锅包子。这条路我走了三年，每一步都算数。",
    "image_url": "/images/2026-06-23-0.jpg",
    "image_author": "",
    "created_at": "2026-06-23T17:20:10.152Z"
  },
  {
    "id": "dd3202a6-4551-48be-bf48-020ab6608882",
    "date": "2026-06-23",
    "category": "励志",
    "title": "早班路上",
    "content": "闹钟响了三遍才爬起来，地铁晃得站不稳。可窗外有光透进来，比昨天更亮一点。",
    "image_url": "/images/2026-06-23-1.jpg",
    "image_author": "",
    "created_at": "2026-06-23T17:20:16.485Z"
  },
  {
    "id": "c8bb82d9-5c40-4c0b-be89-d2b92c43484e",
    "date": "2026-06-23",
    "category": "励志",
    "title": "夜行",
    "content": "今天又加班到深夜，走出大楼时保安说辛苦了。路灯把影子拉得很长，抬头看，月亮还在。",
    "image_url": "/images/2026-06-23-2.jpg",
    "image_author": "",
    "created_at": "2026-06-23T17:20:21.543Z"
  },
  {
    "id": "8e624fc7-06f5-4e9c-b526-d4700a45c09d",
    "date": "2026-06-23",
    "category": "励志",
    "title": "冬夜通勤",
    "content": "加班出来，路灯把影子拉得很长。风吹冷脸的时候，忽然觉得——能这样一步步往前走，也挺好。",
    "image_url": "/images/2026-06-23-3.jpg",
    "image_author": "",
    "created_at": "2026-06-23T17:20:23.664Z"
  },
  {
    "id": "6938e9f3-140d-4ae8-9d3a-0563ae051ca5",
    "date": "2026-06-23",
    "category": "情感",
    "title": "雨天独处",
    "content": "窗外雨声淅沥，泡了杯热茶，翻到相册里那张合影。有些朋友不常联系，但一想起来，心里就暖。要不下次聚聚？",
    "image_url": "/images/2026-06-23-4.jpg",
    "image_author": "",
    "created_at": "2026-06-23T17:20:25.980Z"
  },
  {
    "id": "2a34b10d-1fb0-4b07-84bf-24323d8f5939",
    "date": "2026-06-23",
    "category": "情感",
    "title": "晚安的温度",
    "content": "刚挂掉和妈妈的视频，她那边已经晚上十一点了，还在念叨我有没有好好吃饭。有些关心，隔着屏幕也能暖到心里。",
    "image_url": "/images/2026-06-23-5.jpg",
    "image_author": "",
    "created_at": "2026-06-23T17:20:28.052Z"
  },
  {
    "id": "21f1ab8f-816e-44d9-aff7-ee54c2f41254",
    "date": "2026-06-23",
    "category": "情感",
    "title": "想说的话",
    "content": "雨天，翻到和妈妈视频的截图。她总说没事，却悄悄把镜头转向刚做好的红烧肉。",
    "image_url": "/images/2026-06-23-6.jpg",
    "image_author": "",
    "created_at": "2026-06-23T17:20:29.905Z"
  },
  {
    "id": "65152162-af14-45bf-b63d-d50678e8f026",
    "date": "2026-06-23",
    "category": "情感",
    "title": "雨天想起",
    "content": "下雨天收拾旧照片，翻到那张一起淋雨的笑脸。点开对话框，又关掉，有些想念，不说出来也甜。",
    "image_url": "/images/2026-06-23-7.jpg",
    "image_author": "",
    "created_at": "2026-06-23T17:20:31.935Z"
  },
  {
    "id": "4ad733e8-a2ad-4178-8bc2-6ace906573a3",
    "date": "2026-06-23",
    "category": "早安",
    "title": "早安，简单日常",
    "content": "咬一口烤到微焦的吐司，咖啡香和晨光一起涌进来。出门前摸了摸口袋——钥匙、耳机、好心情，一样不少。",
    "image_url": "/images/2026-06-23-8.jpg",
    "image_author": "",
    "created_at": "2026-06-23T17:20:34.137Z"
  },
  {
    "id": "6ef0ec1e-2ed4-453d-99af-9ea444f1f137",
    "date": "2026-06-23",
    "category": "早安",
    "title": "早安·日常·4uu",
    "content": "阳光刚好洒在咖啡杯沿上，咬一口酥脆吐司，窗外的风在催我出门了。",
    "image_url": "/images/2026-06-23-9.jpg",
    "image_author": "",
    "created_at": "2026-06-23T17:20:44.693Z"
  },
  {
    "id": "7bb625c4-c3b5-43b5-83ee-c8dac3beca2c",
    "date": "2026-06-23",
    "category": "早安",
    "title": "清晨小事",
    "content": "煎蛋在锅里滋滋响，咖啡香飘满厨房。推开窗，微风刚好，出门的步子都轻快了几分。",
    "image_url": "/images/2026-06-23-10.jpg",
    "image_author": "",
    "created_at": "2026-06-23T17:20:46.841Z"
  },
  {
    "id": "b5fcf865-c210-4a6d-b54f-55568ef0d875",
    "date": "2026-06-23",
    "category": "早安",
    "title": "早安，阳光",
    "content": "咬一口烤得焦脆的吐司，咖啡香在舌尖散开。阳光正好，脚步轻快，今天也从好好吃完早餐开始。",
    "image_url": "/images/2026-06-23-11.jpg",
    "image_author": "",
    "created_at": "2026-06-23T17:20:50.577Z"
  },
  {
    "id": "cd29ff0e-d32a-40fc-b3f2-76f56e45d08a",
    "date": "2026-06-23",
    "category": "晚安",
    "title": "关灯前的五分钟",
    "content": "空调嗡嗡响，窗外路灯在窗帘上画了一条线。手机放下的那一刻，世界突然特别安静。",
    "image_url": "/images/2026-06-23-12.jpg",
    "image_author": "",
    "created_at": "2026-06-23T17:20:52.648Z"
  },
  {
    "id": "84ea9cfc-d80c-4988-a3f8-1e2ad5c33ac7",
    "date": "2026-06-23",
    "category": "晚安",
    "title": "收工",
    "content": "洗完澡躺在床上，头发还湿着。窗外最后一盏灯暗了，今天的疲惫都沉进枕头里。就这样吧。",
    "image_url": "/images/2026-06-23-13.jpg",
    "image_author": "",
    "created_at": "2026-06-23T17:20:54.311Z"
  },
  {
    "id": "14f8d06b-f133-4c83-969a-f2eac1e4347d",
    "date": "2026-06-23",
    "category": "晚安",
    "title": "今夜",
    "content": "关灯前的三分钟，窗外的路灯比星星亮。今天的一切，都停在这里了。",
    "image_url": "/images/2026-06-23-14.jpg",
    "image_author": "",
    "created_at": "2026-06-23T17:20:57.718Z"
  },
  {
    "id": "90971031-ffc9-430e-a7b4-65869a73ac2e",
    "date": "2026-06-23",
    "category": "晚安",
    "title": "夜晚的褶皱",
    "content": "关灯前的最后一眼，窗外的灯光比星星还亮。今天的情绪都揉进枕头里了，就这样吧。",
    "image_url": "/images/2026-06-23-15.jpg",
    "image_author": "",
    "created_at": "2026-06-23T17:20:59.737Z"
  },
  {
    "id": "7d98cefb-aa8d-43b4-9693-19bd72c76287",
    "date": "2026-06-23",
    "category": "日常",
    "title": "周末闲散",
    "content": "买菜回来，顺手收拾了冰箱，发现上周买的土豆发芽了。扔了，晚上煮了碗面，凑合吃吧。",
    "image_url": "/images/2026-06-23-16.jpg",
    "image_author": "",
    "created_at": "2026-06-23T17:21:02.146Z"
  },
  {
    "id": "024a0983-472a-4d5f-b133-47029029a305",
    "date": "2026-06-23",
    "category": "日常",
    "title": "阳台上的闲工夫",
    "content": "下午没啥事，在阳台发了会儿呆，顺便把攒了一周的葱剥了。",
    "image_url": "/images/2026-06-23-17.jpg",
    "image_author": "",
    "created_at": "2026-06-23T17:21:05.506Z"
  },
  {
    "id": "d77554b7-03ba-4ff2-b4dd-6ea8148da8c7",
    "date": "2026-06-23",
    "category": "日常",
    "title": "煮面论英雄",
    "content": "冰箱只剩鸡蛋和两片菜叶，煮了碗面，居然还挺香。果然饿的时候，啥都好吃。",
    "image_url": "/images/2026-06-23-18.jpg",
    "image_author": "",
    "created_at": "2026-06-23T17:21:07.656Z"
  },
  {
    "id": "f4143e47-b88e-48d4-a57f-1ff5af4788e5",
    "date": "2026-06-23",
    "category": "日常",
    "title": "做饭小记",
    "content": "今晚试着做了个番茄炒蛋，虽然卖相一般，但味道居然还行，吃完还有点小成就感。",
    "image_url": "/images/2026-06-23-19.jpg",
    "image_author": "",
    "created_at": "2026-06-23T17:21:12.884Z"
  },
  {
    "id": "7b214459-0470-41b0-9b56-1ab95490d84c",
    "date": "2026-06-22",
    "category": "励志",
    "title": "微光",
    "content": "闹钟响的时候天还没亮，但我知道，每一个这样的早晨都会让我离想要的自己更近一步。",
    "image_url": "/images/2026-06-22-0.jpg",
    "image_author": "",
    "created_at": "2026-06-22T18:50:39.381Z"
  },
  {
    "id": "b1137834-45ca-4413-a765-a9c7fb240f4c",
    "date": "2026-06-22",
    "category": "励志",
    "title": "六点闹钟",
    "content": "六点的闹钟响了三次，我醒了两次。第三次按掉的时候，突然觉得，能把自己从被窝里拽出来，已经赢了今天一半。",
    "image_url": "/images/2026-06-22-1.jpg",
    "image_author": "",
    "created_at": "2026-06-22T18:50:42.248Z"
  },
  {
    "id": "0e2e5c06-3df9-4e71-b355-5e226c5b6102",
    "date": "2026-06-22",
    "category": "励志",
    "title": "方向感",
    "content": "早起的地铁挤得变形，但看到窗外天光一点点亮起来，就觉得今天又往前挪了一小步。",
    "image_url": "/images/2026-06-22-2.jpg",
    "image_author": "",
    "created_at": "2026-06-22T18:50:44.141Z"
  },
  {
    "id": "7d5a4b37-b22c-4f26-865e-dd235e3ab271",
    "date": "2026-06-22",
    "category": "励志",
    "title": "小小的胜利",
    "content": "闹钟响了就起，今天又赢了一次。这周第三次运动，打卡完成。生活不就是这样，在平凡里和自己较劲。",
    "image_url": "/images/2026-06-22-3.jpg",
    "image_author": "",
    "created_at": "2026-06-22T18:50:46.166Z"
  },
  {
    "id": "6212c52b-7f2f-4043-9601-8e1a4c301fb9",
    "date": "2026-06-22",
    "category": "情感",
    "title": "旧时光",
    "content": "翻到一张老照片，想起那个一起淋过大雨的傍晚。有些人啊，连想念都变成了一种温柔的日常。",
    "image_url": "/images/2026-06-22-4.jpg",
    "image_author": "",
    "created_at": "2026-06-22T18:50:50.225Z"
  },
  {
    "id": "b58ac9be-57b5-473a-aac0-86d0ae5efd5f",
    "date": "2026-06-22",
    "category": "情感",
    "title": "雨天寄念",
    "content": "雨打在窗上，手机里循环着老歌。突然想起你，翻到聊天记录，上次说“下次一起吃饭”还是三个月前。",
    "image_url": "/images/2026-06-22-5.jpg",
    "image_author": "",
    "created_at": "2026-06-22T18:50:53.834Z"
  },
  {
    "id": "c0caf4f3-f204-4f2e-8760-f62e73e2cc0a",
    "date": "2026-06-22",
    "category": "情感",
    "title": "下雨天的想念",
    "content": "窗外的雨声很轻，像在替我说那些藏了很久的话——想你了，是那种翻翻聊天记录，却不知道该从哪里开始说的想念。",
    "image_url": "/images/2026-06-22-6.jpg",
    "image_author": "",
    "created_at": "2026-06-22T18:50:55.897Z"
  },
  {
    "id": "e88bcacc-35ad-41a8-b523-03952b12ab27",
    "date": "2026-06-22",
    "category": "情感",
    "title": "雨天信号·7f1",
    "content": "下雨天，翻到和爸妈的聊天记录。他们总说家里也下雨，问我有没有带伞。其实我知道，他们只是想知道我过得好不好。",
    "image_url": "/images/2026-06-22-7.jpg",
    "image_author": "",
    "created_at": "2026-06-22T18:51:06.140Z"
  },
  {
    "id": "c3eb76bd-3cf3-4c2e-abcb-75e0dbac7a32",
    "date": "2026-06-22",
    "category": "早安",
    "title": "早安时光",
    "content": "煎蛋在锅里滋滋响，咖啡香飘满屋，推开门，晨光刚好落在肩上。",
    "image_url": "/images/2026-06-22-8.jpg",
    "image_author": "",
    "created_at": "2026-06-22T18:51:08.145Z"
  },
  {
    "id": "6a3866fd-5b4f-4ae1-a7ee-064bb5d18b8e",
    "date": "2026-06-22",
    "category": "早安",
    "title": "早安时分",
    "content": "咬了一口热吐司，咖啡香飘满屋子。窗外阳光刚洒进来，该出门了，今天也要好好过。",
    "image_url": "/images/2026-06-22-9.jpg",
    "image_author": "",
    "created_at": "2026-06-22T18:51:12.038Z"
  },
  {
    "id": "61910117-7327-4b40-8232-8d4a044dba49",
    "date": "2026-06-22",
    "category": "早安",
    "title": "早安·晨间小记",
    "content": "阳光溜进窗缝，咖啡香飘满屋。咬一口酥脆吐司，出门去迎接今日的小确幸。",
    "image_url": "/images/2026-06-22-10.jpg",
    "image_author": "",
    "created_at": "2026-06-22T18:51:13.957Z"
  },
  {
    "id": "66be02da-2e7a-4092-b944-56bebd4fdc57",
    "date": "2026-06-22",
    "category": "早安",
    "title": "晨间序曲",
    "content": "咬了一口烤脆的吐司边，咖啡的热气刚好朦胧了窗玻璃。该出门了，阳光斜斜地铺在路上，踩上去软软的。今天也要好好过。",
    "image_url": "/images/2026-06-22-11.jpg",
    "image_author": "",
    "created_at": "2026-06-22T18:51:17.480Z"
  },
  {
    "id": "54f51375-f59c-433e-8044-c86dccbf21f0",
    "date": "2026-06-22",
    "category": "晚安",
    "title": "夜灯",
    "content": "洗完澡，关了大灯。窗外的路灯刚好透进来，照出一天的影子。累了，就放下吧。",
    "image_url": "/images/2026-06-22-12.jpg",
    "image_author": "",
    "created_at": "2026-06-22T18:51:19.344Z"
  },
  {
    "id": "f24e1cfd-b344-4c6d-a2a5-6e3a1aa39289",
    "date": "2026-06-22",
    "category": "晚安",
    "title": "一天落幕",
    "content": "灯关了，窗帘留一条缝。夜很安静，月光慢慢爬进来，落在手边。今天的事，就让它留在今天吧。",
    "image_url": "/images/2026-06-22-13.jpg",
    "image_author": "",
    "created_at": "2026-06-22T18:51:22.993Z"
  },
  {
    "id": "8be129fb-cffa-4c67-9dfc-1f96edc1c208",
    "date": "2026-06-22",
    "category": "晚安",
    "title": "今晚",
    "content": "洗完澡靠在床头，看窗外路灯把树影投在天花板上。今天就到这里吧，剩下的明天再说。",
    "image_url": "/images/2026-06-22-14.jpg",
    "image_author": "",
    "created_at": "2026-06-22T18:51:24.687Z"
  },
  {
    "id": "456a9f36-fb01-4c35-b666-b533551c3eff",
    "date": "2026-06-22",
    "category": "晚安",
    "title": "一天收束",
    "content": "热水冲走了整天的疲惫，现在躺下来，听夜色慢慢沉淀。窗外的灯一盏盏熄了，我也该把自己还给自己了。",
    "image_url": "/images/2026-06-22-15.jpg",
    "image_author": "",
    "created_at": "2026-06-22T18:51:29.879Z"
  },
  {
    "id": "c9756570-b3de-4756-8cf0-71149edd4891",
    "date": "2026-06-22",
    "category": "日常",
    "title": "日常小确幸",
    "content": "下午去菜场买了把青菜，回家煮了碗面，咸淡刚好，吃完瘫沙发上发了会呆，挺舒服。",
    "image_url": "/images/2026-06-22-16.jpg",
    "image_author": "",
    "created_at": "2026-06-22T18:51:32.541Z"
  },
  {
    "id": "8b83cb8e-9162-4ceb-a084-1f7a866efe25",
    "date": "2026-06-22",
    "category": "日常",
    "title": "今日份满足",
    "content": "收拾完房间，又去菜市场晃了一圈，买了把青菜回来煮面。味道还行，没翻车。",
    "image_url": "/images/2026-06-22-17.jpg",
    "image_author": "",
    "created_at": "2026-06-22T18:51:37.637Z"
  },
  {
    "id": "def999c6-5624-484b-bdc6-64aac2442605",
    "date": "2026-06-22",
    "category": "日常",
    "title": "今天有点闲",
    "content": "自己炒了个菜，卖相一般但味道还行。阳台发了会呆，好像啥也没干，但挺舒服的。",
    "image_url": "/images/2026-06-22-18.jpg",
    "image_author": "",
    "created_at": "2026-06-22T18:51:39.743Z"
  },
  {
    "id": "7a20c9b0-81bd-4a2d-83ad-18e84e70abee",
    "date": "2026-06-22",
    "category": "日常",
    "title": "周末小记",
    "content": "买了把青菜，炒了盘蛋炒饭，吃撑了。下楼遛了一圈，拎了袋橘子回来。日子就这么过呗。",
    "image_url": "/images/2026-06-22-19.jpg",
    "image_author": "",
    "created_at": "2026-06-22T18:51:42.028Z"
  },
  {
    "id": "7e74dbe7-dcd3-42cf-a6b8-7d1709e46c60",
    "date": "2026-06-21",
    "category": "励志",
    "title": "早班轨道",
    "content": "早起的地铁挤成罐头，但窗外的光从没迟到过。每一站都有人下车，而我还在车上。",
    "image_url": "/images/2026-06-21-0.jpg",
    "image_author": "",
    "created_at": "2026-06-21T16:48:28.677Z"
  },
  {
    "id": "d2cee6c6-4fcf-4ac3-8e4b-6aaec0edf281",
    "date": "2026-06-21",
    "category": "励志",
    "title": "坚持的力量",
    "content": "六点的闹钟响了三次，第四次终于坐起来。困是真的，但心里清楚——每一步都在靠近想要的自己。",
    "image_url": "/images/2026-06-21-1.jpg",
    "image_author": "",
    "created_at": "2026-06-21T16:48:31.068Z"
  },
  {
    "id": "77bab1e0-8b3a-4f18-a8b1-753b0748863d",
    "date": "2026-06-21",
    "category": "励志",
    "title": "路上的光",
    "content": "六点半的闹钟响了三次才爬起来，晨光刚好照进厨房。煎蛋糊了，咖啡苦了，但新的一天还是值得期待。",
    "image_url": "/images/2026-06-21-2.jpg",
    "image_author": "",
    "created_at": "2026-06-21T16:48:33.401Z"
  },
  {
    "id": "12550176-fc1e-4fd1-84cf-5756b00cb183",
    "date": "2026-06-21",
    "category": "励志",
    "title": "平凡的坚持·01k",
    "content": "熬夜改的方案第二天被推翻，重来的时候发现比上次顺手了。原来弯路也在偷偷铺路。",
    "image_url": "/images/2026-06-21-3.jpg",
    "image_author": "",
    "created_at": "2026-06-21T16:48:42.089Z"
  },
  {
    "id": "b362392b-254e-440d-8fd9-194d225be538",
    "date": "2026-06-21",
    "category": "情感",
    "title": "雨天电话",
    "content": "下雨天，视频接通时妈妈正在包饺子，镜头对着沾满面粉的手。没说想念，但我们都笑得很慢。",
    "image_url": "/images/2026-06-21-4.jpg",
    "image_author": "",
    "created_at": "2026-06-21T16:48:44.243Z"
  },
  {
    "id": "8d4bf3c9-2cf6-4647-911b-6599a07dcd4a",
    "date": "2026-06-21",
    "category": "情感",
    "title": "下雨天的温暖",
    "content": "雨天窝在沙发里，翻到和你们一起吃饭的照片。有些朋友，不常联系，却一直住在我心里最暖和的地方。",
    "image_url": "/images/2026-06-21-5.jpg",
    "image_author": "",
    "created_at": "2026-06-21T16:48:47.670Z"
  },
  {
    "id": "f392731c-0a96-4858-8a53-8685f5cdc9bf",
    "date": "2026-06-21",
    "category": "情感",
    "title": "雨天",
    "content": "下雨天，翻到去年和朋友吃饭的照片，笑着笑着就安静了。想发条消息，却只打了一句：今天雨很大，记得带伞。",
    "image_url": "/images/2026-06-21-6.jpg",
    "image_author": "",
    "created_at": "2026-06-21T16:48:49.380Z"
  },
  {
    "id": "7a0bfb8f-5f4e-4703-b033-dc989f2fc3d6",
    "date": "2026-06-21",
    "category": "情感",
    "title": "雨天的小事",
    "content": "下雨天，翻到手机里去年和爸妈视频的截图，那时候窗外也是这样的雨声。今天特意打了个电话，听见他们喊我吃饭的声音。",
    "image_url": "/images/2026-06-21-7.jpg",
    "image_author": "",
    "created_at": "2026-06-21T16:48:51.541Z"
  },
  {
    "id": "ea57620f-8916-4ce9-817e-3d195b702225",
    "date": "2026-06-21",
    "category": "早安",
    "title": "清晨信号",
    "content": "咬一口酥脆吐司，咖啡香在杯沿打转。推开门，风里有露水的味道——今天也要好好走路。",
    "image_url": "/images/2026-06-21-8.jpg",
    "image_author": "",
    "created_at": "2026-06-21T16:48:58.062Z"
  },
  {
    "id": "c8f2a5d2-e2b8-4444-97f3-bb33570a5efa",
    "date": "2026-06-21",
    "category": "早安",
    "title": "早安，出门",
    "content": "咬一口热吐司，咖啡香飘满屋。推开门，晨风刚好，阳光刚好，新的一天刚刚好。",
    "image_url": "/images/2026-06-21-9.jpg",
    "image_author": "",
    "created_at": "2026-06-21T16:49:00.294Z"
  },
  {
    "id": "b7322a7d-cc34-4ebe-b032-35c961e96663",
    "date": "2026-06-21",
    "category": "早安",
    "title": "早安·简单开启",
    "content": "咬一口脆脆的烤吐司，咖啡香飘满厨房。阳光刚好照进门，该出门了，今天也慢慢来。",
    "image_url": "/images/2026-06-21-10.jpg",
    "image_author": "",
    "created_at": "2026-06-21T16:49:04.463Z"
  },
  {
    "id": "82bf3407-e492-4179-8aab-e23c642857f4",
    "date": "2026-06-21",
    "category": "早安",
    "title": "早安·晨间小事",
    "content": "吐司边缘烤得刚好酥脆，咖啡香飘满厨房。推开门，阳光还带着露水的味道。吃饱了，出发。",
    "image_url": "/images/2026-06-21-11.jpg",
    "image_author": "",
    "created_at": "2026-06-21T16:49:08.142Z"
  },
  {
    "id": "09c829c8-a2a5-43f6-bf58-500057684e26",
    "date": "2026-06-21",
    "category": "晚安",
    "title": "夜安",
    "content": "关掉最后一盏灯，窗外是城市微弱的呼吸。把一天的疲倦交给枕头，留点安静给自己。就这样吧。",
    "image_url": "/images/2026-06-21-12.jpg",
    "image_author": "",
    "created_at": "2026-06-21T16:49:09.686Z"
  },
  {
    "id": "f47fecc9-5009-44a9-aebf-a6ef16cf9738",
    "date": "2026-06-21",
    "category": "晚安",
    "title": "今天收工",
    "content": "洗完澡躺下来，窗外的灯光渐渐安静了。白天的事在脑子里过了一遍，也没什么特别，今天就到这里吧。",
    "image_url": "/images/2026-06-21-13.jpg",
    "image_author": "",
    "created_at": "2026-06-21T16:49:12.925Z"
  },
  {
    "id": "212fc324-75fe-411b-b73b-b246326fcb45",
    "date": "2026-06-21",
    "category": "晚安",
    "title": "夜的情书",
    "content": "关灯前看了眼窗外，楼宇的灯火一点一点熄灭。今天的所有，都融化在这片安静里了。",
    "image_url": "/images/2026-06-21-14.jpg",
    "image_author": "",
    "created_at": "2026-06-21T16:49:14.975Z"
  },
  {
    "id": "3e9b809c-38ff-4788-913b-e2a97a1dd173",
    "date": "2026-06-21",
    "category": "晚安",
    "title": "收进夜色",
    "content": "洗完澡躺下来，窗外路灯把树影映在天花板上。今天就到这里吧，剩下的，交给夜晚去消化。",
    "image_url": "/images/2026-06-21-15.jpg",
    "image_author": "",
    "created_at": "2026-06-21T16:49:16.974Z"
  },
  {
    "id": "b740e29f-7394-4ffc-b2b0-452e4237c36d",
    "date": "2026-06-21",
    "category": "日常",
    "title": "今日份烟火气",
    "content": "买菜回来路过花店，顺手带了把洋甘菊。煮了锅番茄鸡蛋面，边吃边看夕阳，日子简单就挺好。",
    "image_url": "/images/2026-06-21-16.jpg",
    "image_author": "",
    "created_at": "2026-06-21T16:49:20.260Z"
  },
  {
    "id": "3540f8e7-f6d2-4ada-ab68-241de5abcb59",
    "date": "2026-06-21",
    "category": "日常",
    "title": "周末日常",
    "content": "收拾了一上午屋子，终于能坐阳台发呆。风挺舒服，垃圾桶空空的，心情也跟着轻快了。",
    "image_url": "/images/2026-06-21-17.jpg",
    "image_author": "",
    "created_at": "2026-06-21T16:49:24.990Z"
  },
  {
    "id": "5e25cbd5-4118-487f-90be-dc3efca202ba",
    "date": "2026-06-21",
    "category": "日常",
    "title": "周三流水账",
    "content": "下班回来炒了盘土豆丝，锅差点糊了，但配米饭是真香。吃完下楼遛了半小时，就图个凉快。",
    "image_url": "/images/2026-06-21-18.jpg",
    "image_author": "",
    "created_at": "2026-06-21T16:49:27.240Z"
  },
  {
    "id": "f52ce220-b3fb-4513-a44b-d14d43c722b5",
    "date": "2026-06-21",
    "category": "日常",
    "title": "普通一天",
    "content": "下午收拾了房间，扔了三大袋东西，空出来的地儿看着真舒坦。晚上炒了个青菜，火候正好，配碗白粥，舒服。",
    "image_url": "/images/2026-06-21-19.jpg",
    "image_author": "",
    "created_at": "2026-06-21T16:49:29.172Z"
  },
  {
    "id": "266016fb-86fd-4fae-9a3e-b403e54dbc1c",
    "date": "2026-06-20",
    "category": "励志",
    "title": "早班地铁",
    "content": "早起的地铁挤到变形，但看着窗外越来越亮的天色，觉得这一路的颠簸都有了意义。",
    "image_url": "/images/2026-06-20-0.jpg",
    "image_author": "",
    "created_at": "2026-06-20T16:23:49.023Z"
  },
  {
    "id": "6d155fa1-316e-41ba-89ee-f8156c13c9a3",
    "date": "2026-06-20",
    "category": "励志",
    "title": "方向比速度重要",
    "content": "闹钟响了两遍才爬起来，但今天比昨天早起了十分钟。路还长，走得慢点没关系，别停就行。",
    "image_url": "/images/2026-06-20-1.jpg",
    "image_author": "",
    "created_at": "2026-06-20T16:23:51.148Z"
  },
  {
    "id": "1b330190-6c00-419a-8a65-f82733eca16b",
    "date": "2026-06-20",
    "category": "励志",
    "title": "今日份的坚持",
    "content": "加班到楼下的便利店还亮着灯，买关东煮时突然觉得，生活就像这锅汤，慢慢熬，总会入味的。",
    "image_url": "/images/2026-06-20-2.jpg",
    "image_author": "",
    "created_at": "2026-06-20T16:23:54.009Z"
  },
  {
    "id": "ea53457d-db8c-456b-90bb-4d9437832384",
    "date": "2026-06-20",
    "category": "励志",
    "title": "向光而行",
    "content": "昨晚加班到凌晨，今早依然赶上了六点半的地铁。窗外天刚亮，突然觉得，不放弃的人，总能看到黎明。",
    "image_url": "/images/2026-06-20-3.jpg",
    "image_author": "",
    "created_at": "2026-06-20T16:23:56.342Z"
  },
  {
    "id": "8f47570c-3bd6-4534-b16d-1409485e41ef",
    "date": "2026-06-20",
    "category": "情感",
    "title": "有光",
    "content": "视频通话里妈妈站在厨房说今天做了你爱吃的菜。我在这边笑着点头，突然把手机拿近了些，想让那个画面再清楚一点。",
    "image_url": "/images/2026-06-20-4.jpg",
    "image_author": "",
    "created_at": "2026-06-20T16:23:58.729Z"
  },
  {
    "id": "c86e2215-18ba-4e1f-b531-8f3a11aed4db",
    "date": "2026-06-20",
    "category": "情感",
    "title": "雨天来电",
    "content": "下雨天，妈妈打来视频，说家里也下了。她把镜头对准窗外，我俩隔着屏幕，一起听同一场雨。",
    "image_url": "/images/2026-06-20-5.jpg",
    "image_author": "",
    "created_at": "2026-06-20T16:24:02.715Z"
  },
  {
    "id": "c5b69234-55cf-4529-85a1-e5462355bfce",
    "date": "2026-06-20",
    "category": "情感",
    "title": "下雨的傍晚",
    "content": "视频接通的那一刻，妈妈在厨房炒菜，爸爸凑过来看屏幕。没说想念，但我们都笑了很久。",
    "image_url": "/images/2026-06-20-6.jpg",
    "image_author": "",
    "created_at": "2026-06-20T16:24:04.799Z"
  },
  {
    "id": "80af424a-8420-4026-a2a8-3950c44a6eb3",
    "date": "2026-06-20",
    "category": "情感",
    "title": "雨天的念想",
    "content": "雨声淅沥，翻到相册里那张一起吃饭的照片。很想问一句，你那里下雨了吗？话到嘴边又删了。",
    "image_url": "/images/2026-06-20-7.jpg",
    "image_author": "",
    "created_at": "2026-06-20T16:24:07.748Z"
  },
  {
    "id": "d6cf41e6-d9ce-48d8-bf5a-906605c84a9d",
    "date": "2026-06-20",
    "category": "早安",
    "title": "早安，浅尝",
    "content": "晨跑回来，路过面包店，买了刚出炉的可颂，配一杯不加糖的黑咖。窗外的阳光正好落进杯子里。",
    "image_url": "/images/2026-06-20-8.jpg",
    "image_author": "",
    "created_at": "2026-06-20T16:24:10.552Z"
  },
  {
    "id": "e35d335e-b1f7-4098-b1b8-2b2ecced2863",
    "date": "2026-06-20",
    "category": "早安",
    "title": "早安·一口阳光",
    "content": "吐司在烤面包机里弹起时，恰好看到窗外第一缕阳光。咬一口酥脆，咖啡香飘进今天的节奏里。",
    "image_url": "/images/2026-06-20-9.jpg",
    "image_author": "",
    "created_at": "2026-06-20T16:24:14.588Z"
  },
  {
    "id": "70709e0d-e7f0-49b0-8961-dd76e5e1d5c3",
    "date": "2026-06-20",
    "category": "早安",
    "title": "早安",
    "content": "晨跑时遇见的桂花香，和刚煮好的咖啡一样提神。咬一口脆脆的吐司，今天也要轻快出门。",
    "image_url": "/images/2026-06-20-10.jpg",
    "image_author": "",
    "created_at": "2026-06-20T16:24:17.894Z"
  },
  {
    "id": "05e73b5a-8c06-481e-b872-5cb8e2ce5545",
    "date": "2026-06-20",
    "category": "早安",
    "title": "早间速写",
    "content": "咬了一口烤吐司，脆响在耳边炸开，像清晨的闹钟。再抿一口黑咖啡，苦味过后是回甘——这就是出门前的仪式感。",
    "image_url": "/images/2026-06-20-11.jpg",
    "image_author": "",
    "created_at": "2026-06-20T16:24:20.380Z"
  },
  {
    "id": "78d67936-8925-4a51-9fc5-9026f1e6a785",
    "date": "2026-06-20",
    "category": "晚安",
    "title": "今夜收工",
    "content": "关了大灯，留一盏小夜灯。窗外的路灯还亮着，但我的今天已经可以消失在枕头里了。",
    "image_url": "/images/2026-06-20-12.jpg",
    "image_author": "",
    "created_at": "2026-06-20T16:24:22.549Z"
  },
  {
    "id": "b278c959-2671-4011-9392-11516e825489",
    "date": "2026-06-20",
    "category": "晚安",
    "title": "一天终了",
    "content": "洗完澡躺在床上，灯关了，窗外路灯的光透进来。今天所有的事，都停在句号这里了。",
    "image_url": "/images/2026-06-20-13.jpg",
    "image_author": "",
    "created_at": "2026-06-20T16:24:26.185Z"
  },
  {
    "id": "8d49b4fb-88bd-40bf-a9c7-6e3c76083e4f",
    "date": "2026-06-20",
    "category": "晚安",
    "title": "夜色正好",
    "content": "把这一天的光都关了，窗外的路灯还在亮。洗完澡躺下，感觉身体慢慢沉进床垫里，像一片叶子落回水面。",
    "image_url": "/images/2026-06-20-14.jpg",
    "image_author": "",
    "created_at": "2026-06-20T16:24:28.837Z"
  },
  {
    "id": "a0491c55-4f9a-45d9-9b79-c85d70237a47",
    "date": "2026-06-20",
    "category": "晚安",
    "title": "收尾时刻",
    "content": "关掉最后一盏灯，窗外的城市还在呼吸。今天所有的话，都留给今晚的风去说。",
    "image_url": "/images/2026-06-20-15.jpg",
    "image_author": "",
    "created_at": "2026-06-20T16:24:32.867Z"
  },
  {
    "id": "87a87455-e097-4293-b9b3-d5000c3b6ce7",
    "date": "2026-06-20",
    "category": "日常",
    "title": "周五小确幸",
    "content": "冰箱里剩的菜随便炒了炒，居然还挺好吃。阳台站了三分钟，风挺舒服。",
    "image_url": "/images/2026-06-20-16.jpg",
    "image_author": "",
    "created_at": "2026-06-20T16:24:35.910Z"
  },
  {
    "id": "49534a02-3fb5-4ba8-9254-4b6cbcc4f0d9",
    "date": "2026-06-20",
    "category": "日常",
    "title": "今天就这样",
    "content": "切菜切到手指，贴个创可贴继续炒。味道还行，就是有点咸，下回少放点酱油。",
    "image_url": "/images/2026-06-20-17.jpg",
    "image_author": "",
    "created_at": "2026-06-20T16:24:40.042Z"
  },
  {
    "id": "80af2bb3-52f1-4656-9556-090ace4ea678",
    "date": "2026-06-20",
    "category": "日常",
    "title": "周末随记",
    "content": "洗菜切菜煮面，忙活半小时吃光十分钟。收拾完阳台发了会呆，发现袜子又少了一只。",
    "image_url": "/images/2026-06-20-18.jpg",
    "image_author": "",
    "created_at": "2026-06-20T16:24:45.183Z"
  },
  {
    "id": "65b26818-99bc-43dd-94cb-5cdc80e5cda7",
    "date": "2026-06-20",
    "category": "日常",
    "title": "周六流水账",
    "content": "早上去菜市场逛了一圈，买了点排骨和青菜。回来炖了锅汤，收拾了下房间，下午在阳台发了会呆。一天就这么过去了，还挺舒服。",
    "image_url": "/images/2026-06-20-19.jpg",
    "image_author": "",
    "created_at": "2026-06-20T16:24:50.530Z"
  },
  {
    "id": "7eca7446-9928-449c-83da-3e04d6cea914",
    "date": "2026-06-19",
    "category": "励志",
    "title": "闹钟响了三遍",
    "content": "闹钟响了三遍才爬起来，晨光里豆浆的热气模糊了车窗。日子像这样一天天重复，但我知道，每次出发都在靠近那个更好的自己。",
    "image_url": "/images/2026-06-19-0.jpg",
    "image_author": "",
    "created_at": "2026-06-19T17:21:37.892Z"
  },
  {
    "id": "06d21b04-592a-4c3e-a5eb-3d318c8dfbe5",
    "date": "2026-06-19",
    "category": "励志",
    "title": "日常",
    "content": "早起的地铁挤得人站不稳，但站着的这半小时，刚好读完一章书。日子就这样一点点往前挪。",
    "image_url": "/images/2026-06-19-1.jpg",
    "image_author": "",
    "created_at": "2026-06-19T17:21:44.916Z"
  },
  {
    "id": "2e44c07d-9d01-401b-af66-1bcac916c536",
    "date": "2026-06-19",
    "category": "励志",
    "title": "晨光",
    "content": "六点半的闹钟响了三次，天还没全亮。泡咖啡的时候看见窗外的梧桐冒了新芽，原来春天在谁都看不见的地方悄悄使劲。",
    "image_url": "/images/2026-06-19-2.jpg",
    "image_author": "",
    "created_at": "2026-06-19T17:21:48.575Z"
  },
  {
    "id": "8340417e-df7a-4b0c-a3b1-a1cff0d5a556",
    "date": "2026-06-19",
    "category": "励志",
    "title": "清晨的微光",
    "content": "六点半的闹钟响了三次才爬起来，窗外的路灯还没灭。但想到今天又能比昨天多懂一点，困意也就散了。",
    "image_url": "/images/2026-06-19-3.jpg",
    "image_author": "",
    "created_at": "2026-06-19T17:21:50.769Z"
  },
  {
    "id": "2e08ad19-01de-4c40-a8d8-cbf79ac6d2af",
    "date": "2026-06-19",
    "category": "情感",
    "title": "陪",
    "content": "下雨天和妈妈视频，她说家里也在下。挂了电话，窗外的雨声好像变轻了。",
    "image_url": "/images/2026-06-19-4.jpg",
    "image_author": "",
    "created_at": "2026-06-19T17:21:52.519Z"
  },
  {
    "id": "51d2702d-57ad-4775-83f1-a5c7040b36fe",
    "date": "2026-06-19",
    "category": "情感",
    "title": "雨天的想念",
    "content": "下雨了，翻到和爸妈的聊天记录，才发现上次视频已经是两周前。屏幕那头的唠叨，现在听来格外温暖。",
    "image_url": "/images/2026-06-19-5.jpg",
    "image_author": "",
    "created_at": "2026-06-19T17:21:57.894Z"
  },
  {
    "id": "3b082352-4356-4c79-932a-b60d3c91faaf",
    "date": "2026-06-19",
    "category": "情感",
    "title": "默契",
    "content": "和好朋友吃饭，不用找话题，安安静静各自吃，偶尔抬头碰杯，就很舒服。",
    "image_url": "/images/2026-06-19-6.jpg",
    "image_author": "",
    "created_at": "2026-06-19T17:21:59.789Z"
  },
  {
    "id": "84d9d9de-65de-4dd6-9422-eebb538ea832",
    "date": "2026-06-19",
    "category": "情感",
    "title": "煮茶等雨停",
    "content": "视频里妈妈在厨房忙活，我隔着屏幕说“好香”。她笑着让我回家吃，突然觉得距离没那么远了。",
    "image_url": "/images/2026-06-19-7.jpg",
    "image_author": "",
    "created_at": "2026-06-19T17:22:05.220Z"
  },
  {
    "id": "958a2019-e790-46e4-9f69-f94ac7c2f5db",
    "date": "2026-06-19",
    "category": "早安",
    "title": "清晨小记",
    "content": "咖啡香飘进房间，阳光刚好洒在吐司上。咬一口酥脆，新的一天就这么简单开始。",
    "image_url": "/images/2026-06-19-8.jpg",
    "image_author": "",
    "created_at": "2026-06-19T17:22:08.990Z"
  },
  {
    "id": "4a578f7e-534c-4198-b9bc-17d534089227",
    "date": "2026-06-19",
    "category": "早安",
    "title": "早安，新的一天",
    "content": "咬一口酥脆的吐司，咖啡香飘满屋，推开窗户深吸口气。阳光正好，出门踩晨光去。",
    "image_url": "/images/2026-06-19-9.jpg",
    "image_author": "",
    "created_at": "2026-06-19T17:22:10.795Z"
  },
  {
    "id": "38da3f9c-a8d5-4a0d-afbc-1778dc9a10d5",
    "date": "2026-06-19",
    "category": "早安",
    "title": "早安·小确幸",
    "content": "热好的牛奶冒着白气，吐司烤得焦黄刚好。咬一口，再赶早班车，这样的清晨刚刚好。",
    "image_url": "/images/2026-06-19-10.jpg",
    "image_author": "",
    "created_at": "2026-06-19T17:22:12.723Z"
  },
  {
    "id": "42cbff91-ac75-48fd-8980-7acfbf649a1c",
    "date": "2026-06-19",
    "category": "早安",
    "title": "早安·简单开始",
    "content": "煎蛋在锅里滋滋响，咖啡香飘满厨房。咬一口吐司，推开窗，清晨的风刚刚好。",
    "image_url": "/images/2026-06-19-11.jpg",
    "image_author": "",
    "created_at": "2026-06-19T17:22:14.864Z"
  },
  {
    "id": "4e73a816-c3e6-4b29-89a4-8272f6ce4652",
    "date": "2026-06-19",
    "category": "晚安",
    "title": "夜归",
    "content": "热水冲走了今天的褶皱。关灯前又看了一会儿窗外，万家灯火慢慢熄灭，像一天的句号缓缓画完。",
    "image_url": "/images/2026-06-19-12.jpg",
    "image_author": "",
    "created_at": "2026-06-19T17:22:18.787Z"
  },
  {
    "id": "752c6159-ea60-4549-befe-4b387f0a9e68",
    "date": "2026-06-19",
    "category": "晚安",
    "title": "今日已封存",
    "content": "窗外的灯一盏盏暗了，我关上最后一盏。热水冲掉的疲惫，此刻正缓缓沉淀进夜色里。",
    "image_url": "/images/2026-06-19-13.jpg",
    "image_author": "",
    "created_at": "2026-06-19T17:22:20.635Z"
  },
  {
    "id": "3da37b17-5382-4579-b4f0-79a70baba7bf",
    "date": "2026-06-19",
    "category": "晚安",
    "title": "关灯前",
    "content": "窗帘留了一条缝，让月光溜进来。热水澡洗掉了今天所有的奔波，关灯以后，房间只剩呼吸和夜晚的安静。",
    "image_url": "/images/2026-06-19-14.jpg",
    "image_author": "",
    "created_at": "2026-06-19T17:22:22.768Z"
  },
  {
    "id": "446e500d-ea95-4f66-8eba-9636738de27c",
    "date": "2026-06-19",
    "category": "晚安",
    "title": "今日终章",
    "content": "擦了擦湿漉漉的头发，关上灯。窗外远处还有几盏亮着的灯，像白天的故事没讲完。今天就到这里吧。",
    "image_url": "/images/2026-06-19-15.jpg",
    "image_author": "",
    "created_at": "2026-06-19T17:22:24.880Z"
  },
  {
    "id": "c36b382b-d81a-4f7a-be31-ad87d0bc819c",
    "date": "2026-06-19",
    "category": "日常",
    "title": "今天也是平平无奇的一天",
    "content": "买菜回来发现自己忘了买葱，算了，凑合着炒。吃完瘫沙发上发呆，也挺好。",
    "image_url": "/images/2026-06-19-16.jpg",
    "image_author": "",
    "created_at": "2026-06-19T17:22:28.130Z"
  },
  {
    "id": "3d634988-3f03-4862-846b-5ed8cdcffffa",
    "date": "2026-06-19",
    "category": "日常",
    "title": "周一晚上",
    "content": "炒了个土豆丝，糊了。又煮了包泡面，还挺香。吃饱了瘫沙发上发呆，感觉也挺好。",
    "image_url": "/images/2026-06-19-17.jpg",
    "image_author": "",
    "created_at": "2026-06-19T17:22:30.851Z"
  },
  {
    "id": "e08b7a52-af01-4999-8d90-9e7b263c42e2",
    "date": "2026-06-19",
    "category": "日常",
    "title": "日常碎片",
    "content": "下午收拾房间，翻出好多旧东西，愣是坐地上翻了一整本相册才继续干活。",
    "image_url": "/images/2026-06-19-18.jpg",
    "image_author": "",
    "created_at": "2026-06-19T17:22:33.011Z"
  },
  {
    "id": "261f7ea5-c61b-4888-b044-3d71f377e10c",
    "date": "2026-06-19",
    "category": "日常",
    "title": "自己做饭",
    "content": "今天试着做了个番茄炒蛋，居然没糊锅，还挺好吃。突然觉得，认真吃饭也是一种本事。",
    "image_url": "/images/2026-06-19-19.jpg",
    "image_author": "",
    "created_at": "2026-06-19T17:22:34.944Z"
  },
  {
    "id": "d42e934e-575b-47a3-b576-3cc159e8ab0c",
    "date": "2026-06-18",
    "category": "励志",
    "title": "向下扎根",
    "content": "闹钟响的时候，我告诉自己再躺五分钟。然后发现，早起这件事和跑步一样，最难的是穿鞋的那一刻。",
    "image_url": "/images/2026-06-18-0.jpg",
    "image_author": "",
    "created_at": "2026-06-18T18:08:02.328Z"
  },
  {
    "id": "9d0f23e3-9a3c-4ccd-95e9-133c942765df",
    "date": "2026-06-18",
    "category": "励志",
    "title": "方向",
    "content": "闹钟响了三遍才爬起来，晨跑时腿还发软。可跑到第三公里，风变轻了，天也亮了。",
    "image_url": "/images/2026-06-18-1.jpg",
    "image_author": "",
    "created_at": "2026-06-18T18:08:05.411Z"
  },
  {
    "id": "99e02fc6-3c26-473a-bd95-931f883418fb",
    "date": "2026-06-18",
    "category": "励志",
    "title": "早起的意义",
    "content": "闹钟响的时候犹豫了三秒，还是起来了。窗外的天还没亮透，但我知道，这条路走下去，光会越来越亮。",
    "image_url": "/images/2026-06-18-2.jpg",
    "image_author": "",
    "created_at": "2026-06-18T18:08:07.990Z"
  },
  {
    "id": "1762414a-ee29-4071-959c-ba08f75aa457",
    "date": "2026-06-18",
    "category": "励志",
    "title": "早班车",
    "content": "六点半的闹钟响了三次才爬起来，跑向地铁站时看见初升的太阳。原来每一天，都是这样咬着牙迎上去的。",
    "image_url": "/images/2026-06-18-3.jpg",
    "image_author": "",
    "created_at": "2026-06-18T18:08:11.637Z"
  },
  {
    "id": "a110878f-1d23-4dc5-9234-34f5c5cd1a05",
    "date": "2026-06-18",
    "category": "情感",
    "title": "雨天想念",
    "content": "雨声淅淅沥沥的，突然想起你上次说喜欢这种天气。翻出聊天记录，才发现我们已经一个月没联系了。",
    "image_url": "/images/2026-06-18-4.jpg",
    "image_author": "",
    "created_at": "2026-06-18T18:08:16.713Z"
  },
  {
    "id": "b1726cb1-ddd2-4338-b897-2ceba22be30b",
    "date": "2026-06-18",
    "category": "情感",
    "title": "想念的重量",
    "content": "收拾旧物翻出一张照片，愣了好久。有些人许久没联系了，可看到某样东西时，还是会想起，像老朋友一样轻轻问一句：你还好吗。",
    "image_url": "/images/2026-06-18-5.jpg",
    "image_author": "",
    "created_at": "2026-06-18T18:08:20.178Z"
  },
  {
    "id": "d99c6697-9eea-444e-b6c4-fde40d4863d1",
    "date": "2026-06-18",
    "category": "情感",
    "title": "下雨天的思念",
    "content": "雨声滴滴答答，翻到相册里一起吃饭的旧照片，突然很想你们。不知道下次见面，会不会还是老样子？",
    "image_url": "/images/2026-06-18-6.jpg",
    "image_author": "",
    "created_at": "2026-06-18T18:08:22.787Z"
  },
  {
    "id": "774fd1ac-a9da-4d9e-bd2a-f2db8683925d",
    "date": "2026-06-18",
    "category": "情感",
    "title": "雨天想起你",
    "content": "雨滴敲窗的下午，翻到去年和妈妈视频的截图。她笑得那么开心，我却好久没主动打过去了。",
    "image_url": "/images/2026-06-18-7.jpg",
    "image_author": "",
    "created_at": "2026-06-18T18:08:25.414Z"
  },
  {
    "id": "fc2cf3de-1fed-4d1c-a5b8-380c73828695",
    "date": "2026-06-18",
    "category": "早安",
    "title": "早安·日常",
    "content": "晨光洒进厨房，咖啡香混着煎蛋的滋滋声。咬一口吐司，推门去迎接今天的风。",
    "image_url": "/images/2026-06-18-8.jpg",
    "image_author": "",
    "created_at": "2026-06-18T18:08:28.612Z"
  },
  {
    "id": "524aeb8f-1ff9-46cd-9cd3-661d7d82202c",
    "date": "2026-06-18",
    "category": "早安",
    "title": "早安·晨味",
    "content": "阳光斜照进厨房，吐司机弹起的那刻，咖啡香刚好漫过来。咬一口酥脆，嗯，今天开了个好头。",
    "image_url": "/images/2026-06-18-9.jpg",
    "image_author": "",
    "created_at": "2026-06-18T18:08:32.875Z"
  },
  {
    "id": "dc80a4c7-b9bc-4517-8de4-1654cb88c3af",
    "date": "2026-06-18",
    "category": "早安",
    "title": "早安·简单",
    "content": "咬一口热吐司，阳光刚好洒进来。推门出发，清晨的风带着咖啡香，今天这样开始就很好。",
    "image_url": "/images/2026-06-18-10.jpg",
    "image_author": "",
    "created_at": "2026-06-18T18:08:37.333Z"
  },
  {
    "id": "4c0d61ed-f1f3-470d-9847-fa5bc91077af",
    "date": "2026-06-18",
    "category": "早安",
    "title": "今早的阳光",
    "content": "烤了片吐司，咖啡正好有点烫嘴。推开窗发现巷口的梧桐叶黄了一半，原来秋天早就到门口了。",
    "image_url": "/images/2026-06-18-11.jpg",
    "image_author": "",
    "created_at": "2026-06-18T18:08:40.342Z"
  },
  {
    "id": "1f23feda-46f3-4fc6-aa95-ff9a2e175acc",
    "date": "2026-06-18",
    "category": "晚安",
    "title": "安静的收尾",
    "content": "灯关了，窗帘留一条缝，让夜色透进来。今天的热闹和疲惫，连同未说完的话，都留在这一天里。",
    "image_url": "/images/2026-06-18-12.jpg",
    "image_author": "",
    "created_at": "2026-06-18T18:08:43.956Z"
  },
  {
    "id": "e4e3c74f-5fda-4d2e-b4ee-3c3a6d30f9eb",
    "date": "2026-06-18",
    "category": "晚安",
    "title": "卸下一天",
    "content": "洗完澡，关了灯，窗外的路灯还亮着。今天就到这里，身体躺平，思绪慢慢沉下去。",
    "image_url": "/images/2026-06-18-13.jpg",
    "image_author": "",
    "created_at": "2026-06-18T18:08:46.178Z"
  },
  {
    "id": "20dab29a-c7c6-422f-a54b-8b3735c7015b",
    "date": "2026-06-18",
    "category": "晚安",
    "title": "沉淀",
    "content": "灯熄了。窗外的光一点一点暗下来，像这一天的心情慢慢沉到心底。洗澡时水声哗哗，此刻只剩呼吸。",
    "image_url": "/images/2026-06-18-14.jpg",
    "image_author": "",
    "created_at": "2026-06-18T18:08:50.307Z"
  },
  {
    "id": "a8ebac9f-3431-4298-9f20-fd2af57c930e",
    "date": "2026-06-18",
    "category": "晚安",
    "title": "一天结束",
    "content": "关灯前的最后一秒，看见窗外路灯把光铺在夜色上。该把今天的心事，都交给柔软的枕头了。",
    "image_url": "/images/2026-06-18-15.jpg",
    "image_author": "",
    "created_at": "2026-06-18T18:08:56.366Z"
  },
  {
    "id": "e1557799-6170-4809-8111-2c2980fb4810",
    "date": "2026-06-18",
    "category": "日常",
    "title": "买菜日常",
    "content": "今天去菜市场转了一圈，买了点青菜和肉。回家随便炒了两个菜，吃完感觉还挺满足。",
    "image_url": "/images/2026-06-18-16.jpg",
    "image_author": "",
    "created_at": "2026-06-18T18:08:59.087Z"
  },
  {
    "id": "12fd206d-f8e1-4526-9df4-9dc5888c9b5c",
    "date": "2026-06-18",
    "category": "日常",
    "title": "饭扫光",
    "content": "周末吭哧吭哧收拾了一下午屋子，累得半死。晚上煮了碗面，呼噜呼噜吃完，感觉又活过来了。",
    "image_url": "/images/2026-06-18-17.jpg",
    "image_author": "",
    "created_at": "2026-06-18T18:09:03.255Z"
  },
  {
    "id": "d078ad74-96d8-4b13-9f09-56cb0ab97665",
    "date": "2026-06-18",
    "category": "日常",
    "title": "今天的厨房战绩",
    "content": "洗菜切菜煮面，顺手炒了个蛋。吃完发现灶台擦了三遍，这大概就是普通人最大的成就感。",
    "image_url": "/images/2026-06-18-18.jpg",
    "image_author": "",
    "created_at": "2026-06-18T18:09:06.995Z"
  },
  {
    "id": "f44fc94a-67a1-4805-b1c7-2447bf71ed18",
    "date": "2026-06-18",
    "category": "日常",
    "title": "阳台发呆",
    "content": "买完菜路过花摊，顺手带了把桔梗。回来洗菜切菜，忙活一通，最后坐在阳台发了十分钟呆。",
    "image_url": "/images/2026-06-18-19.jpg",
    "image_author": "",
    "created_at": "2026-06-18T18:09:11.535Z"
  },
  {
    "id": "b9b10e9c-2b7d-461e-a7c6-fc57e006ce30",
    "date": "2026-06-17",
    "category": "励志",
    "title": "路",
    "content": "加班到凌晨打车回家，司机说辛苦了。我说没事，这条路是自己选的，走完它才能看到天亮。",
    "image_url": "/images/2026-06-17-0.jpg",
    "image_author": "",
    "created_at": "2026-06-17T17:50:46.863Z"
  },
  {
    "id": "e8e92444-4594-456f-a5a1-24428c44718b",
    "date": "2026-06-17",
    "category": "励志",
    "title": "晨间随想",
    "content": "闹钟响了三次才爬起来，电梯里遇见同样困倦的邻居。但看着窗外渐渐亮起来的天光，忽然觉得每天重复的坚持本身，就是答案。",
    "image_url": "/images/2026-06-17-1.jpg",
    "image_author": "",
    "created_at": "2026-06-17T17:50:50.553Z"
  },
  {
    "id": "44462655-9765-4674-8471-9874671d3172",
    "date": "2026-06-17",
    "category": "励志",
    "title": "朝前的方向",
    "content": "闹钟响了五次才爬起来，但拉开窗帘的时候，刚好看见日出。路上有点堵，不过今天步子比昨天稳了一些。",
    "image_url": "/images/2026-06-17-2.jpg",
    "image_author": "",
    "created_at": "2026-06-17T17:50:54.542Z"
  },
  {
    "id": "10cdf001-83cb-4e73-a456-c63c296bf2bc",
    "date": "2026-06-17",
    "category": "励志",
    "title": "早起的安排",
    "content": "六点半闹钟响的时候犹豫了三秒，还是爬起来把晨跑换成了地铁上的阅读。多挤了十几分钟，但今天的目标清单提前打勾了一项。",
    "image_url": "/images/2026-06-17-3.jpg",
    "image_author": "",
    "created_at": "2026-06-17T17:50:58.648Z"
  },
  {
    "id": "757857dc-f73e-4d42-8092-99091f06a864",
    "date": "2026-06-17",
    "category": "情感",
    "title": "雨天记",
    "content": "窗外的雨声刚好，翻到相册里和你们吃饭的照片。好像有些话不需要说，光是想起就觉得日子很轻。",
    "image_url": "/images/2026-06-17-4.jpg",
    "image_author": "",
    "created_at": "2026-06-17T17:51:00.661Z"
  },
  {
    "id": "a144133f-171e-4f1f-b9d4-be840b0eb024",
    "date": "2026-06-17",
    "category": "情感",
    "title": "雨天的电话",
    "content": "下雨了，翻到之前和爸妈视频的截图。他们总说一切都好，我也学会了报喜不报忧。大概是雨声太密，突然特别想听听他们的声音。",
    "image_url": "/images/2026-06-17-5.jpg",
    "image_author": "",
    "created_at": "2026-06-17T17:51:07.832Z"
  },
  {
    "id": "78bd6ea7-c4d9-4d87-a2b9-3be900e2351d",
    "date": "2026-06-17",
    "category": "情感",
    "title": "雨天旧友",
    "content": "雨声滴答，翻到老照片，想起一起淋雨赶路的夜晚。打开聊天框，打了又删，最后只发了句：今天下雨了。",
    "image_url": "/images/2026-06-17-6.jpg",
    "image_author": "",
    "created_at": "2026-06-17T17:51:10.152Z"
  },
  {
    "id": "46926534-73ba-48ce-806b-f195f351a9f1",
    "date": "2026-06-17",
    "category": "情感",
    "title": "刚挂掉视频",
    "content": "刚挂掉和爸妈的视频，妈妈还在说记得多喝热水。窗外雨停了，我好像也没那么想家了。",
    "image_url": "/images/2026-06-17-7.jpg",
    "image_author": "",
    "created_at": "2026-06-17T17:51:12.512Z"
  },
  {
    "id": "ede88ba4-36d7-4f3e-a857-ed9940b69ae2",
    "date": "2026-06-17",
    "category": "早安",
    "title": "早安·慢生活",
    "content": "咬下第一口煎蛋时，阳光刚好落在吐司上。窗外有风，咖啡很烫，今天不想赶时间。",
    "image_url": "/images/2026-06-17-8.jpg",
    "image_author": "",
    "created_at": "2026-06-17T17:51:16.268Z"
  },
  {
    "id": "88551bf1-b8ab-4a4b-9dee-833ff0dc133e",
    "date": "2026-06-17",
    "category": "早安",
    "title": "早安信号",
    "content": "咖啡的香气是清晨的闹钟，咬一口吐司，看阳光慢慢铺满餐桌。出门时风很轻，脚步也跟着轻快起来。",
    "image_url": "/images/2026-06-17-9.jpg",
    "image_author": "",
    "created_at": "2026-06-17T17:51:18.764Z"
  },
  {
    "id": "daac938a-ae70-4f09-8bbb-6123fbcf6b23",
    "date": "2026-06-17",
    "category": "早安",
    "title": "早安·日常·3wr",
    "content": "咬一口烤到焦黄的吐司，咖啡香在空气里打转。阳光把影子拉长，今天的路，慢慢走。",
    "image_url": "/images/2026-06-17-10.jpg",
    "image_author": "",
    "created_at": "2026-06-17T17:51:28.646Z"
  },
  {
    "id": "f5c70ce5-20ee-47e6-ab70-ed6783d01422",
    "date": "2026-06-17",
    "category": "早安",
    "title": "早安·简单满足",
    "content": "咬一口热吐司，煎蛋的边有点脆。阳光刚好洒在杯沿，出门前给自己一个笑。新一天，慢慢来。",
    "image_url": "/images/2026-06-17-11.jpg",
    "image_author": "",
    "created_at": "2026-06-17T17:51:34.558Z"
  },
  {
    "id": "45648603-0e21-4a00-bb00-4d12cb89eb76",
    "date": "2026-06-17",
    "category": "晚安",
    "title": "夜已深",
    "content": "洗完澡躺下来，窗帘留了一条缝。路灯的光溜进来，像今晚没说出口的话，就让它留在夜里吧。",
    "image_url": "/images/2026-06-17-12.jpg",
    "image_author": "",
    "created_at": "2026-06-17T17:51:38.043Z"
  },
  {
    "id": "6a39e1eb-2248-489b-88a6-70837937379b",
    "date": "2026-06-17",
    "category": "晚安",
    "title": "结束",
    "content": "关了灯，窗外路灯把树影投在天花板上。今天所有的话，都停在这里了。",
    "image_url": "/images/2026-06-17-13.jpg",
    "image_author": "",
    "created_at": "2026-06-17T17:51:41.551Z"
  },
  {
    "id": "507cea85-77af-4caa-ac6c-304fc15f0088",
    "date": "2026-06-17",
    "category": "晚安",
    "title": "收进夜里的光",
    "content": "洗完澡躺在床上，窗外路灯把树影投在天花板上。今天就到这里吧，剩下的情绪和念头，都留给夜晚慢慢消化。",
    "image_url": "/images/2026-06-17-14.jpg",
    "image_author": "",
    "created_at": "2026-06-17T17:51:44.448Z"
  },
  {
    "id": "b546601f-4b82-4226-893f-9ed58f56081f",
    "date": "2026-06-17",
    "category": "晚安",
    "title": "一天的句点",
    "content": "洗完澡关灯，窗帘缝里漏进一束路灯光。今天所有的事，就停在这里吧。",
    "image_url": "/images/2026-06-17-15.jpg",
    "image_author": "",
    "created_at": "2026-06-17T17:51:49.954Z"
  },
  {
    "id": "1ef67884-76de-44f0-a14c-c21b66eb541a",
    "date": "2026-06-17",
    "category": "日常",
    "title": "日常琐碎",
    "content": "刚拖完地，瘫沙发上刷手机，窗外有鸟叫。突然觉得，不用赶时间的下午真不错。",
    "image_url": "/images/2026-06-17-16.jpg",
    "image_author": "",
    "created_at": "2026-06-17T17:51:58.565Z"
  },
  {
    "id": "05c72e59-3d35-4f4f-99fe-c583cdd2b79d",
    "date": "2026-06-17",
    "category": "日常",
    "title": "买菜逛吃",
    "content": "今天去菜市场转了一圈，买了把青菜和半斤肉，回家随便炒了炒，居然比外卖香多了。",
    "image_url": "/images/2026-06-17-17.jpg",
    "image_author": "",
    "created_at": "2026-06-17T17:52:00.895Z"
  },
  {
    "id": "b0f0ab0f-ee70-497c-8216-2921af506287",
    "date": "2026-06-17",
    "category": "日常",
    "title": "烟火气",
    "content": "晚上炒了盘土豆丝，醋放多了酸得直皱眉，但就着热米饭全吃光了。这就是我的日常，简单又真实。",
    "image_url": "/images/2026-06-17-18.jpg",
    "image_author": "",
    "created_at": "2026-06-17T17:52:07.285Z"
  },
  {
    "id": "dc196f13-5529-4adf-88ce-bcca5cfa4488",
    "date": "2026-06-17",
    "category": "日常",
    "title": "周末瞎忙",
    "content": "收拾了两小时房间，结果最大的成就就是找到了一双失踪一个月的袜子。",
    "image_url": "/images/2026-06-17-19.jpg",
    "image_author": "",
    "created_at": "2026-06-17T17:52:10.261Z"
  }
]